{
  "name": "backend-isgop",
  "version": "1.0.0",
  "description": "Backend boilerplate for ISGOP built with Express, TypeScript, Prisma, and PostgreSQL.",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
